{
  "name": "xiaohongshu-video-publish",
  "version": "1.1.0",
  "description": "小红书视频一键发布技能 - 使用 OpenClaw 内置浏览器自动上传视频并发布",
  "type": "module",
  "scripts": {
    "publish": "node scripts/publish.js",
    "check-env": "node scripts/check-env.js",
    "test": "node scripts/publish.js --video=test.mp4 --title=测试视频 --debug"
  },
  "keywords": [
    "xiaohongshu",
    "video",
    "publish",
    "automation",
    "openclaw"
  ],
  "author": "Baoyu Skills Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "engineStrict": true,
  "dependencies": {
    "commander": "^12.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": false
    }
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "files": [
    "scripts/",
    "examples/",
    "SKILL.md",
    "README.md",
    "package.json"
  ]
}

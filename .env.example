# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============ LLM API ============
# Kimi API (主力 - 文案生成)
KIMI_API_KEY=your_kimi_api_key

# Claude API (核心创意)
CLAUDE_API_KEY=your_claude_api_key

# OpenAI API (备用)
OPENAI_API_KEY=your_openai_api_key

# ============ 数据源 API ============
# TrendRadar (如有 API)
TREND_RADAR_API_KEY=

# 智小红 API
ZHIXIAOHONG_API_KEY=

# 智小抖 API
ZHIXIAODOU_API_KEY=

# 巨量算数 (爬虫方式，无需 API)

# ============ 存储配置 ============
# MinIO 对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=materials

# ============ 视频处理 ============
# FFmpeg 路径 (如使用系统安装可留空)
FFMPEG_PATH=

# ============ 发布平台 ============
# 抖音
DOUYIN_COOKIE=

# 小红书
XIAOHONGSHU_COOKIE=

# B 站
BILIBILI_COOKIE=

# ============ 其他配置 ============
# 项目根目录
PROJECT_ROOT=C:/Users/爽爽/lixiaolong

# 素材存储目录
MATERIALS_DIR=${PROJECT_ROOT}/materials

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
